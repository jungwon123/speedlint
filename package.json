{
  "name": "speedlint",
  "private": true,
  "description": "Web performance optimization library with auto-fix",
  "scripts": {
    "build": "turbo build",
    "test": "turbo test",
    "test:watch": "turbo test -- --watch",
    "lint": "biome check .",
    "lint:fix": "biome check --fix .",
    "format": "biome format --write .",
    "typecheck": "turbo typecheck",
    "clean": "turbo clean"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "@changesets/cli": "^2.27.0",
    "@types/node": "^25.5.0",
    "changesets": "^1.0.0",
    "tsup": "^8.3.0",
    "turbo": "^2.3.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20"
  }
}
