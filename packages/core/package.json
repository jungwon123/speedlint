{
  "name": "@speedlint/core",
  "version": "0.1.0",
  "description": "Web performance analysis engine with auto-fix",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/jungwon123/speedlint.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/jungwon123/speedlint#readme",
  "keywords": ["performance", "lighthouse", "web-vitals", "bundle-size", "lcp", "cls", "fcp", "lint", "auto-fix"],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@swc/core": "^1.10.0"
  },
  "devDependencies": {
    "tsup": "^8.3.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
