{
	"name": "@speedlint/plugin-vue",
	"version": "0.1.0",
	"description": "Vue performance rules for speedlint",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/jungwon123/speedlint.git",
		"directory": "packages/plugin-vue"
	},
	"keywords": ["speedlint", "vue", "nuxt", "performance", "lint"],
	"type": "module",
	"main": "./dist/index.cjs",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js",
			"require": "./dist/index.cjs"
		}
	},
	"files": ["dist"],
	"scripts": {
		"build": "tsup",
		"test": "vitest run",
		"typecheck": "tsc --noEmit",
		"clean": "rm -rf dist .turbo"
	},
	"dependencies": {
		"@speedlint/core": "workspace:*"
	},
	"devDependencies": {
		"tsup": "^8.3.0",
		"typescript": "^5.7.0",
		"vitest": "^3.0.0"
	}
}
